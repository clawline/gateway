RELAY_HOST=0.0.0.0
RELAY_PORT=19080
RELAY_ADMIN_TOKEN=replace-me
RELAY_PUBLIC_BASE_URL=https://relay.example.com
RELAY_PLUGIN_BACKEND_URL=ws://127.0.0.1:19080/backend

LOGTO_ENDPOINT=https://logto.example.com
LOGTO_API_RESOURCE=https://gateway.example.com/api

RELAY_SUPABASE_URL=https://your-project-ref.supabase.co
RELAY_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional fallback / migration inputs
RELAY_CONFIG_PATH=./data/relay-config.json
RELAY_CHANNELS_JSON=

# CORS: comma-separated allowed origins (empty = same-origin only)
CORS_ALLOWED_ORIGINS=https://app.clawlines.net,https://docs.clawlines.net

# Copy to .env.test and adjust for your environment.
# Test gateway runs on a separate port (19181) from dev (19180).
# Test data is isolated by channel id 'e2e-rel'; rel-suite cleans this channel
# at the start of every run.

RELAY_HOST=127.0.0.1
RELAY_PORT=19181
RELAY_ADMIN_TOKEN=rel-test-admin
RELAY_PUBLIC_BASE_URL=http://localhost:19181

# Reuse dev Supabase. Test channel 'e2e-rel' must exist in cl_channels with
# secret matching MOCK_SECRET (default "rel-secret"), and a user in
# cl_channel_users with token matching REL_USER_TOKEN env (default
# "reltoken-1234567890abcdef").
RELAY_SUPABASE_URL=https://db.dora.restry.cn
RELAY_SUPABASE_SERVICE_ROLE_KEY=<service_role_jwt_here>

CORS_ALLOWED_ORIGINS=http://localhost:4026,http://localhost:19181
